# UCLAW Environment — copy to .uclaw/.env and fill in values.
# This file is gitignored.

# LLM Providers
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# Local model server (Ollama default)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_DEFAULT_MODEL=llama3

# VoltAgent
VOLTAGENT_BASE_URL=http://localhost:3141

# Observer
OBSERVER_BASE_URL=http://localhost:7878

# MQTT broker (for IoT)
MQTT_BROKER=localhost
MQTT_PORT=1883

# World state
UCLAW_DB_PATH=.uclaw/world.db
UCLAW_SOCKET=.uclaw/uclaw.sock

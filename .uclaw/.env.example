# UCLAW Local Environment
# Copy this to ~/.uclaw/.env and fill in values.
# This file is NEVER committed to git.

# Anthropic Claude
ANTHROPIC_API_KEY=

# OpenRouter (multi-model)
OPENROUTER_API_KEY=

# Local model (Ollama default)
OLLAMA_BASE_URL=http://localhost:11434

# UCLAW world settings
UCLAW_WORLD_NAME=my-world
UCLAW_VAULT_PATH=~/.uclaw/vault
UCLAW_DB_PATH=~/.uclaw/world.db
UCLAW_AUDIT_PATH=~/.uclaw/audit.jsonl

# Budget limits (USD)
UCLAW_BUDGET_LIMIT=10.00

# Voice (optional)
# WHISPER_MODEL=base
# TTS_ENGINE=system
